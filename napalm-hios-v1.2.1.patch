+    """Convert an SNMP value to a clean string.
+
+    Uses prettyPrint() for types like IpAddress that render as raw bytes
+    via str(), falls back to str() for simple types.
+    """
+    if hasattr(val, 'prettyPrint'):
+        return val.prettyPrint()
+    return str(val)
