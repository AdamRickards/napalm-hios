+            ifindex, ip = parts[0], parts[1]
+            iface = ifmap.get(ifindex, f'if{ifindex}')
+            mac_val = cols.get('mac', b'')
+            arp_table.append({
+                'interface': iface,
+                'mac': _format_mac(mac_val),
